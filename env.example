PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

CORS_ORIGIN=http://localhost:3000
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Optional: absolute uploads path for persistent storage in production.
# Render examples:
# UPLOAD_DIR=/opt/render/project/src/uploads
# UPLOAD_DIR=/var/data/uploads

# Resume/CV storage:
# If Cloudinary is configured, resume uploads use Cloudinary instead of local disk.
# This avoids Render's ephemeral filesystem for CVs.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional folder and delivery mode for resume files.
# `upload` = public URL, `private` / `authenticated` = signed download via admin route.
CLOUDINARY_RESUME_FOLDER=the-cage/resumes
CLOUDINARY_RESUME_DELIVERY_TYPE=upload
# Signed URL lifetime in seconds when using private/authenticated Cloudinary delivery.
RESUME_SIGNED_URL_TTL_SECONDS=900

# First super admin (one-time seed). Set a strong secret, then call POST /api/admin/seed-super-admin with header X-Super-Admin-Secret
SUPER_ADMIN_SECRET=your-one-time-secret-for-seeding-super-admin

# Email (approval/rejection emails to applicants – no password for applicants)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@yourdomain.com
